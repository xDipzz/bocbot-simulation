<sdf version='1.6'>
  <world name='default'>
    <!-- Lighting -->
    <light name='sun' type='directional'>
      <cast_shadows>0</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.95 0.95 0.95 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.3 0.3 -1.0</direction>
    </light>

    <!-- Ground plane -->
    <model name='ground_plane'>
      <static>1</static>
      <link name='link'>
        <collision name='collision'>
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <surface><friction><ode><mu>100</mu><mu2>50</mu2></ode></friction></surface>
        </collision>
        <visual name='visual'>
          <cast_shadows>0</cast_shadows>
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <physics name='default_physics' default='0' type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- EXPANDED OFFICE COMPLEX: 30m x 40m (10 Rooms) -->
    <model name='office_complex'>
      <static>1</static>
      <pose>0 0 0 0 0 0</pose>

      <!-- Office Floor -->
      <link name='office_floor'>
        <pose>0 20 0.005 0 0 0</pose>
        <visual name='vis'>
          <geometry><box><size>30 40 0.01</size></box></geometry>
          <material><script><name>Gazebo/CeilingTiled</name></script></material>
        </visual>
      </link>

      <!-- ==================== OUTER WALLS (3m high) ==================== -->
      <link name='wall_south_l'>
        <pose>-8.75 0 1.5 0 0 0</pose>
        <collision name='col'><geometry><box><size>12.5 0.2 3.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>12.5 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>
      <link name='wall_south_r'>
        <pose>8.75 0 1.5 0 0 0</pose>
        <collision name='col'><geometry><box><size>12.5 0.2 3.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>12.5 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>
      <link name='door_header'>
        <pose>0 0 2.5 0 0 0</pose>
        <collision name='col'><geometry><box><size>5.0 0.2 1.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>5.0 0.2 1.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>
      <link name='wall_north'>
        <pose>0 40 1.5 0 0 0</pose>
        <collision name='col'><geometry><box><size>30.0 0.2 3.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>30.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>
      <link name='wall_west'>
        <pose>-15 20 1.5 0 0 1.5708</pose>
        <collision name='col'><geometry><box><size>40.0 0.2 3.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>40.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>
      <link name='wall_east'>
        <pose>15 20 1.5 0 0 1.5708</pose>
        <collision name='col'><geometry><box><size>40.0 0.2 3.0</size></box></geometry></collision>
        <visual name='vis'><geometry><box><size>40.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual>
      </link>

      <!-- ==================== CORRIDOR WALLS ==================== -->
      <!-- Left (West) -->
      <link name='corr_l_1'><pose>-2.5 1 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>2.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>2.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_l_2'><pose>-2.5 8 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
