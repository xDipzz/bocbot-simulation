      <link name='corr_l_4'><pose>-2.5 24 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_l_5'><pose>-2.5 32 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_l_6'><pose>-2.5 39 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>2.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>2.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>

      <!-- Right (East) -->
      <link name='corr_r_1'><pose>2.5 1 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>2.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>2.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_r_2'><pose>2.5 8 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_r_3'><pose>2.5 16 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_r_4'><pose>2.5 24 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_r_5'><pose>2.5 32 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>4.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>
      <link name='corr_r_6'><pose>2.5 39 1.5 0 0 1.5708</pose><collision name='col'><geometry><box><size>2.0 0.2 3.0</size></box></geometry></collision><visual name='vis'><geometry><box><size>2.0 0.2 3.0</size></box></geometry><material><script><name>Gazebo/White</name></script></material></visual></link>

      <!-- ==================== CROSS WALLS (E-W) ==================== -->
      <!-- Y=8 -->
      <link name='xwall_w8_l'><pose>-12.875 8 0.75 0 0 0</pose><collision name='col'><geometry><box><size>4.25 0.2 1.5</size></box></geometry></collision><visual name='vis'><geometry><box><size>4.25 0.2 1.5</size></box></geometry><material><script><name>Gazebo/Bricks</name></script></material></visual></link>
