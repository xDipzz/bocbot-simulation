    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="back_right_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin rpy="1.5707 0 0" xyz="0.0 0.0 0.0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022"/>
    </inertial>
    <visual>
      <origin rpy="1.5707 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5707 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/Grey</material>
    <!-- ADVANCED MECHANICS: Anisotropic Friction.
           In a 6-wheel skid steer, the wheels MUST slip sideways to turn.
           mu1 (forward friction) is high (1.2) for stair climbing grip.
           mu2 (lateral friction) is extremely low (0.1) so the robot
           can easily rotate on its center axis without fighting itself! -->
    <mu1>1.2</mu1>
    <mu2>0.1</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <joint name="back_right_wheel_joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.9 -0.54 -0.45"/>
    <parent link="right_bogie_link"/>
    <child link="back_right_wheel"/>
    <axis xyz="0.0 3.0 0.0"/>
    <limit effort="100" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
</robot>
