  <!-- LEFT SIDE ROCKER-BOGIE ASSEMBLY -->
  <!-- =============================== -->
  <!-- Left Main Rocker Arm -->
  <link name="left_rocker_arm">
    <inertial>
      <mass value="2.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="-0.05 0.05 -0.05"/>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.05 0.05 -0.05"/>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="left_rocker_arm">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <!-- Left Rocker to Chassis Joint (Pitch Revolute) -->
  <joint name="left_differential_axle" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.15 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" lower="-0.78" upper="0.78" velocity="100"/>
    <dynamics damping="5.0" friction="5.0"/>
  </joint>
  <!-- Left Front Wheel Module -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="2.0"/>
      <origin rpy="1.5707 0 0" xyz="0 0 0"/>
