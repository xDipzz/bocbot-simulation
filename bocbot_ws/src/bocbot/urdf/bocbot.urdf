    <collision>
      <origin rpy="0 0 0" xyz="0.15 0.0 -0.075"/>
      <geometry>
        <box size="0.9 0.06 0.15"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="left_rocker_arm">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <joint name="left_differential_axle" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.39 0.0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0.0 3.0 0.0"/>
    <!-- ADVANCED MECHANICS: Mechanical Hard Stops.
         Changed from continuous back to revolute, but with strictly tuned limits 
         (+/- 0.6 radians). This simulates the physical chassis bumping against 
         the arm, preventing the robot from doing a full backflip over its own wheels. -->
    <limit effort="1000" lower="-0.6" upper="0.6" velocity="10"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.8"/>
      <origin rpy="1.5707 0 0" xyz="0.0 0.0 0.0"/>
      <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022"/>
