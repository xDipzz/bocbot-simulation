<!-- =================================================================================== -->
<robot name="bocbot">
  <!-- Hexapedal Rocker-Bogie Plugin Configuration -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="skid_steer_drive_controller">
      <ros>
        <!-- Removed namespace and remappings to use global /cmd_vel -->
      </ros>
      <update_rate>100.0</update_rate>
      <!-- 3 pairs of wheels -->
      <num_wheel_pairs>3</num_wheel_pairs>
      <odometry_frame>odom</odometry_frame>
      <!-- Left Wheels -->
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>mid_left_wheel_joint</left_joint>
      <left_joint>back_left_wheel_joint</left_joint>
      <!-- Right Wheels -->
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>mid_right_wheel_joint</right_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <!-- Wheel separation and diameter for the scaled model -->
      <wheel_separation>1.7</wheel_separation>
      <wheel_diameter>0.75</wheel_diameter>
      <robot_base_frame>robot_footprint</robot_base_frame>
      <max_wheel_torque>50</max_wheel_torque>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_source>world</odometry_source>
    </plugin>
  </gazebo>
  <!-- camera -->
  <gazebo reference="camera">
    <sensor name="camera_sensor" type="camera">
      <update_rate>30.0</update_rate>
      <always_on>1</always_on>
      <camera name="camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>400</width>
          <height>400</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <ros>
          <namespace>/bocbot</namespace>
          <argument>camera/image_raw:=/bocbot/camera/image</argument>
          <argument>camera/camera_info:=/bocbot/camera/image/camera_info</argument>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera</frame_name>
        <hack_baseline>0.21</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>
  <!-- hokuyo -->
  <gazebo reference="hokuyo">
    <sensor name="head_hokuyo_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-1.570796</min_angle>
            <max_angle>1.570796</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="gazebo_ros_head_hokuyo_controller">
        <ros>
          <namespace>/bocbot</namespace>
          <argument>~/out:=scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>
  <!-- IMU -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace>/bocbot</namespace>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>
  <link name="robot_footprint"/>
  <joint name="robot_footprint_joint" type="fixed">
    <!-- GIANT SCALE SPAWN: 1.5m in the air to allow the monster wheels to unfold -->
    <origin rpy="0 0 0" xyz="0 0 1.5"/>
    <parent link="robot_footprint"/>
    <child link="base_link"/>
  </joint>
  <!-- ======================================================== -->
  <!-- MAIN CHASSIS - 5X SCALE (1.5m Length)                    -->
  <!-- ======================================================== -->
  <link name="base_link">
    <inertial>
      <mass value="50.0"/>
      <!-- Heavy underbelly battery simulation -->
      <origin rpy=" 0 0 0" xyz="0 0 -0.2"/>
      <inertia ixx="5.0" ixy="0" ixz="0" iyy="8.0" iyz="0" izz="10.0"/>
    </inertial>
    <collision name="collision">
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="1.5 1.0 0.6"/>
      </geometry>
    </collision>
    <visual name="chassis_visual">
      <origin rpy=" 0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="1.5 1.0 0.6"/>
      </geometry>
    </visual>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>
  <link name="camera">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.1 0.2 0.1"/>
      </geometry>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.75 0 0"/>
    <child link="camera"/>
    <parent link="base_link"/>
  </joint>
  <gazebo reference="camera">
    <material>Gazebo/Black</material>
  </gazebo>
  <link name="hokuyo">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.15" radius="0.1"/>
      </geometry>
    </visual>
  </link>
  <joint name="hokuyo_joint" type="fixed">
    <origin xyz="0.5 0 0.35"/>
    <child link="hokuyo"/>
    <parent link="base_link"/>
  </joint>
  <gazebo reference="hokuyo">
    <material>Gazebo/Black</material>
  </gazebo>
  <!-- =============================== -->
  <!-- LEFT SIDE ASSEMBLY              -->
  <!-- =============================== -->
  <link name="left_rocker_arm">
    <inertial>
      <mass value="5.0"/>
      <origin rpy="0 0 0" xyz="0.25 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
    </inertial>
    <visual>
      <origin xyz="0.25 0 0"/>
      <geometry>
        <box size="1.7 0.2 0.2"/>
      </geometry>
    </visual>
  </link>
  <gazebo reference="left_rocker_arm">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <joint name="left_differential_axle" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.65 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit effort="10000" lower="-0.6" upper="0.6" velocity="5"/>
    <dynamics damping="100.0" friction="50.0"/>
  </joint>
  <link name="front_left_wheel">
    <inertial>
      <mass value="5.0"/>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <!-- Proportional inertia for large cylinder -->
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.35"/>
    </inertial>
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.375"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.375"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Grey</material>
    <!-- Optimized for massive rover turning -->
    <mu1>1.5</mu1>
    <mu2>0.02</mu2>
    <!-- Almost zero lateral friction to allow easy pivot -->
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <joint name="front_left_wheel_joint" type="continuous">
