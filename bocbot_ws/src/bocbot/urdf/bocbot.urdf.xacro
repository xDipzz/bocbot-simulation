<?xml version='1.0'?>
<robot name="bocbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="bocbot.gazebo" />

  <link name="robot_footprint"></link>

  <joint name="robot_footprint_joint" type="fixed">
    <!-- GIANT SCALE SPAWN: 1.5m in the air to allow the monster wheels to unfold -->
    <origin xyz="0 0 1.5" rpy="0 0 0" />
    <parent link="robot_footprint"/>
    <child link="base_link" />
  </joint>

  <!-- ======================================================== -->
  <!-- MAIN CHASSIS - 5X SCALE (1.5m Length)                    -->
  <!-- ======================================================== -->
  <link name='base_link'>
    <inertial>
      <mass value="50.0"/>
      <!-- Heavy underbelly battery simulation -->
      <origin xyz="0 0 -0.2" rpy=" 0 0 0"/>
      <inertia ixx="5.0" ixy="0" ixz="0" iyy="8.0" iyz="0" izz="10.0" />
    </inertial>
    <collision name='collision'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <geometry><box size="1.2 0.8 0.4"/></geometry>
    </collision>
    <visual name='chassis_visual'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <geometry><box size="1.5 1.0 0.6"/></geometry>
    </visual>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Green</material></gazebo>

  <link name="imu_link"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <joint name="imu_joint" type="fixed"><origin xyz="0 0 0"/><parent link="base_link"/><child link="imu_link"/></joint>

  <link name="camera">
    <visual><origin xyz="0 0 0"/><geometry><box size="0.1 0.2 0.1"/></geometry></visual>
  </link>
  <joint type="fixed" name="camera_joint">
    <origin xyz="0.75 0 0"/><child link="camera"/><parent link="base_link"/>
  </joint>
  <gazebo reference="camera"><material>Gazebo/Black</material></gazebo>

  <link name="hokuyo">
    <visual><origin xyz="0 0 0"/><geometry><cylinder radius="0.1" length="0.15"/></geometry></visual>
  </link>
  <joint type="fixed" name="hokuyo_joint">
    <origin xyz="0.5 0 0.35"/><child link="hokuyo"/><parent link="base_link"/>
  </joint>
  <gazebo reference="hokuyo"><material>Gazebo/Black</material></gazebo>


  <!-- ======================================================== -->
  <!-- MONSTER WHEEL MACRO                                      -->
  <!-- ======================================================== -->
  <xacro:macro name="boc_wheel" params="name parent origin_xyz">
    <link name="${name}">
      <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="1.570796 0 0"/>
        <!-- Proportional inertia for large cylinder -->
        <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.35" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="1.570796 0 0"/>
        <geometry><cylinder length="0.2" radius="0.375"/></geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.570796 0 0"/>
        <geometry><cylinder length="0.2" radius="0.375"/></geometry>
      </collision>
    </link>
    <gazebo reference="${name}">
      <material>Gazebo/Grey</material>
      <!-- Optimized for massive rover turning -->
      <mu1>1.5</mu1>
      <mu2>0.02</mu2> <!-- Almost zero lateral friction to allow easy pivot -->
      <kp>1000000.0</kp>
      <kd>100.0</kd>
    </gazebo>
    <joint name="${name}_joint" type="continuous">
      <origin xyz="${origin_xyz}" rpy="0 0 0"/>
      <parent link="${parent}"/>
      <child link="${name}"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.5" friction="0.5"/>
    </joint>
  </xacro:macro>

  <!-- =============================== -->
  <!-- LEFT SIDE ASSEMBLY              -->
  <!-- =============================== -->
  <link name="left_rocker_arm">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5" />
    </inertial>
    <visual><origin xyz="0.25 0 0"/><geometry><box size="1.7 0.2 0.2"/></geometry></visual>
  </link>
  <gazebo reference="left_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="left_differential_axle" type="revolute">
    <origin xyz="0.0 0.65 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.6" effort="10000" velocity="5"/>
    <dynamics damping="100.0" friction="50.0"/>
  </joint>

  <!-- Front Left Wheel: X=1.0, Y=0.2, Z=-0.5 -->
  <xacro:boc_wheel name="front_left_wheel" parent="left_rocker_arm" origin_xyz="1.0 0.2 -0.5"/>

  <link name="left_bogie_link">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.3" />
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="1.2 0.2 0.2"/></geometry></visual>
  </link>
  <gazebo reference="left_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="left_bogie_pivot" type="revolute">
    <origin xyz="-0.5 0 -0.2" rpy="0 0 0"/>
    <parent link="left_rocker_arm"/>
    <child link="left_bogie_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="5000" velocity="5"/>
    <dynamics damping="50.0" friction="20.0"/>
  </joint>

  <xacro:boc_wheel name="mid_left_wheel" parent="left_bogie_link" origin_xyz="0.5 0.2 -0.3"/>
  <xacro:boc_wheel name="back_left_wheel" parent="left_bogie_link" origin_xyz="-0.5 0.2 -0.3"/>


  <!-- =============================== -->
  <!-- RIGHT SIDE ASSEMBLY             -->
  <!-- =============================== -->
  <link name="right_rocker_arm">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5" />
    </inertial>
    <visual><origin xyz="0.25 0 0"/><geometry><box size="1.7 0.2 0.2"/></geometry></visual>
  </link>
  <gazebo reference="right_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_differential_axle" type="revolute">
    <origin xyz="0.0 -0.65 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_rocker_arm"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.6" effort="10000" velocity="5"/>
    <dynamics damping="100.0" friction="50.0"/>
  </joint>

  <!-- Front Right Wheel -->
  <xacro:boc_wheel name="front_right_wheel" parent="right_rocker_arm" origin_xyz="1.0 -0.2 -0.5"/>

  <link name="right_bogie_link">
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.3" />
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="1.2 0.2 0.2"/></geometry></visual>
  </link>
  <gazebo reference="right_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_bogie_pivot" type="revolute">
    <origin xyz="-0.5 0 -0.2" rpy="0 0 0"/>
    <parent link="right_rocker_arm"/>
    <child link="right_bogie_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="5000" velocity="5"/>
    <dynamics damping="50.0" friction="20.0"/>
  </joint>

  <xacro:boc_wheel name="mid_right_wheel" parent="right_bogie_link" origin_xyz="0.5 -0.2 -0.3"/>
  <xacro:boc_wheel name="back_right_wheel" parent="right_bogie_link" origin_xyz="-0.5 -0.2 -0.3"/>

</robot>