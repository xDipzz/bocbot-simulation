<?xml version='1.0'?>
<robot name="bocbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="bocbot.gazebo" />

  <!-- ======================================================== -->
  <!-- ROBOTIC MECHANICS & KINEMATICS UPGRADE                   -->
  <!-- ======================================================== -->

  <link name="robot_footprint"></link>

  <joint name="robot_footprint_joint" type="fixed">
    <origin xyz="0.0 0.0 0.45" rpy="0 0 0" />
    <parent link="robot_footprint"/>
    <child link="base_link" />
  </joint>

  <!-- Main Chassis -->
  <link name='base_link'>
    <inertial>
      <mass value="4.0"/>
      <!-- ADVANCED MECHANICS: Lowering the Center of Mass (CoM). 
           By shifting the Z origin of the inertia down by 5cm (-0.05), 
           we simulate a heavy battery pack mounted at the very bottom 
           of the hull. This mathematically increases the tip-over angle,
           making it exceptionally stable on steep stairs. -->
      <origin xyz="0.0 0.0 -0.15" rpy=" 0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05" />
    </inertial>
    <collision name='collision'>
      <origin xyz="0.0 0.0 0.0" rpy=" 0 0 0"/>
      <geometry><box size="0.84 0.54 0.3"/></geometry>
    </collision>
    <visual name='chassis_visual'>
      <origin xyz="0.0 0.0 0.0" rpy=" 0 0 0"/>
      <geometry><box size="0.9 0.6 0.36"/></geometry>
    </visual>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Green</material></gazebo>

  <!-- IMU Sensor Link (New System Component) -->
  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="imu_link" />
  </joint>

  <!-- Camera -->
  <link name="camera">
    <visual name="camera_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry><box size="0.09 0.15 0.09"/></geometry>
    </visual>
  </link>
  <joint type="fixed" name="camera_joint">
    <origin xyz="0.45 0.0 0.0" rpy="0 0 0"/>
    <child link="camera"/>
    <parent link="base_link"/>
  </joint>
  <gazebo reference="camera"><material>Gazebo/Black</material></gazebo>

  <!-- Hokuyo LiDAR -->
  <link name="hokuyo">
    <visual name="hokuyo_visual">
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
    </visual>
  </link>
  <joint type="fixed" name="hokuyo_joint">
    <origin xyz="0.3 0.0 0.18" rpy="0 0 0"/>
    <child link="hokuyo"/>
    <parent link="base_link"/>
  </joint>
  <gazebo reference="hokuyo"><material>Gazebo/Black</material></gazebo>


  <!-- ======================================================== -->
  <!-- MACROS FOR CLEAN CODE (Professional Robotics Standard)   -->
  <!-- ======================================================== -->

  <xacro:macro name="boc_wheel" params="name parent origin_xyz">
    <link name="${name}">
      <inertial>
        <mass value="0.8"/>
        <origin xyz="0.0 0.0 0.0" rpy="1.5707 0 0"/>
        <inertia ixx="0.0013" ixy="0" ixz="0" iyy="0.0013" iyz="0" izz="0.0022" />
      </inertial>
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="1.5707 0 0"/>
        <geometry><cylinder length="0.05" radius="0.075"/></geometry>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="1.5707 0 0"/>
        <geometry><cylinder length="0.05" radius="0.075"/></geometry>
      </collision>
    </link>
    <gazebo reference="${name}">
      <material>Gazebo/Grey</material>
      <!-- ADVANCED MECHANICS: Anisotropic Friction.
           In a 6-wheel skid steer, the wheels MUST slip sideways to turn.
           mu1 (forward friction) is high (1.2) for stair climbing grip.
           mu2 (lateral friction) is extremely low (0.1) so the robot
           can easily rotate on its center axis without fighting itself! -->
      <mu1>1.2</mu1>
      <mu2>0.1</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>

    <joint name="${name}_joint" type="continuous">
      <origin xyz="${origin_xyz}" rpy="0 0 0"/>
      <parent link="${parent}"/>
      <child link="${name}"/>
      <axis xyz="0.0 3.0 0.0"/>
      <limit effort="100" velocity="20"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- =============================== -->
  <!-- LEFT SIDE ASSEMBLY              -->
  <!-- =============================== -->

  <link name="left_rocker_arm">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.15 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual><origin xyz="0.15 0.0 0.0" rpy="0 0 0"/><geometry><box size="1.02 0.12 0.12"/></geometry></visual>
    <visual><origin xyz="0.6 0.0 -0.15" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.3"/></geometry></visual>
    <visual><origin xyz="-0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <collision><origin xyz="0.15 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.9 0.06 0.15"/></geometry></collision>
  </link>
  <gazebo reference="left_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="left_differential_axle" type="revolute">
    <origin xyz="0.0 0.39 0.0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_rocker_arm"/>
    <axis xyz="0.0 3.0 0.0"/>
    <!-- ADVANCED MECHANICS: Mechanical Hard Stops.
         Changed from continuous back to revolute, but with strictly tuned limits 
         (+/- 0.6 radians). This simulates the physical chassis bumping against 
         the arm, preventing the robot from doing a full backflip over its own wheels. -->
    <limit lower="-0.6" upper="0.6" effort="1000" velocity="10"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>

  <!-- Instantiate Left Front Wheel -->
  <xacro:boc_wheel name="front_left_wheel" parent="left_rocker_arm" origin_xyz="1.8 0.54 -0.9"/>

  <link name="left_bogie_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual><origin xyz="0.0 0.0 0.0" rpy="0 0 0"/><geometry><box size="0.72 0.12 0.12"/></geometry></visual>
    <visual><origin xyz="0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <visual><origin xyz="-0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <collision><origin xyz="0.0 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.6 0.06 0.15"/></geometry></collision>
  </link>
  <gazebo reference="left_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="left_bogie_pivot" type="revolute">
    <origin xyz="-0.3 0.0 -0.15" rpy="0 0 0"/>
    <parent link="left_rocker_arm"/>
    <child link="left_bogie_link"/>
    <axis xyz="0.0 3.0 0.0"/>
    <!-- Mechanical stop for the bogie (+/- 0.8 radians) -->
    <limit lower="-0.8" upper="0.8" effort="500" velocity="10"/>
    <dynamics damping="3.0" friction="1.0"/>
  </joint>

  <!-- Instantiate Left Mid & Rear Wheels -->
  <xacro:boc_wheel name="mid_left_wheel" parent="left_bogie_link" origin_xyz="0.9 0.54 -0.45"/>
  <xacro:boc_wheel name="back_left_wheel" parent="left_bogie_link" origin_xyz="-0.9 0.54 -0.45"/>


  <!-- =============================== -->
  <!-- RIGHT SIDE ASSEMBLY             -->
  <!-- =============================== -->

  <link name="right_rocker_arm">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.15 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual><origin xyz="0.15 0.0 0.0" rpy="0 0 0"/><geometry><box size="1.02 0.12 0.12"/></geometry></visual>
    <visual><origin xyz="0.6 0.0 -0.15" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.3"/></geometry></visual>
    <visual><origin xyz="-0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <collision><origin xyz="0.15 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.9 0.06 0.15"/></geometry></collision>
  </link>
  <gazebo reference="right_rocker_arm"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_differential_axle" type="revolute">
    <origin xyz="0.0 -0.39 0.0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_rocker_arm"/>
    <axis xyz="0.0 3.0 0.0"/>
    <limit lower="-0.6" upper="0.6" effort="1000" velocity="10"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>

  <!-- Instantiate Right Front Wheel -->
  <xacro:boc_wheel name="front_right_wheel" parent="right_rocker_arm" origin_xyz="1.8 -0.54 -0.9"/>

  <link name="right_bogie_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005" />
    </inertial>
    <visual><origin xyz="0.0 0.0 0.0" rpy="0 0 0"/><geometry><box size="0.72 0.12 0.12"/></geometry></visual>
    <visual><origin xyz="0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <visual><origin xyz="-0.3 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.12 0.12 0.15"/></geometry></visual>
    <collision><origin xyz="0.0 0.0 -0.075" rpy="0 0 0"/><geometry><box size="0.6 0.06 0.15"/></geometry></collision>
  </link>
  <gazebo reference="right_bogie_link"><material>Gazebo/DarkGrey</material></gazebo>

  <joint name="right_bogie_pivot" type="revolute">
    <origin xyz="-0.3 0.0 -0.15" rpy="0 0 0"/>
    <parent link="right_rocker_arm"/>
    <child link="right_bogie_link"/>
    <axis xyz="0.0 3.0 0.0"/>
    <limit lower="-0.8" upper="0.8" effort="500" velocity="10"/>
    <dynamics damping="3.0" friction="1.0"/>
  </joint>

  <!-- Instantiate Right Mid & Rear Wheels -->
  <xacro:boc_wheel name="mid_right_wheel" parent="right_bogie_link" origin_xyz="0.9 -0.54 -0.45"/>
  <xacro:boc_wheel name="back_right_wheel" parent="right_bogie_link" origin_xyz="-0.9 -0.54 -0.45"/>

</robot>